# OTLP ingest key — used by the app being instrumented to send spans
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_INGEST_KEY

# Management API key — used by run.ts to query Honeycomb for evaluation
# Create at https://ui.honeycomb.io/teams/<team>/api_keys with "Query Data" permission
HONEYCOMB_QUERY_API_KEY=YOUR_QUERY_API_KEY

# Honeycomb environment slug for evaluation queries (default: test)
HONEYCOMB_ENV=test

# Optional: key for the Honeycomb MCP the conductor's verifier sub-agent uses to query telemetry
# in the headless agent container (the hosted MCP's OAuth can't run there, so it authenticates by
# API key in the Authorization header). Must be a Honeycomb API key in <KEY_ID>:<SECRET_KEY> form.
# Leave unset to reuse HONEYCOMB_QUERY_API_KEY (works only if that key is in that format).
# HONEYCOMB_MCP_KEY=YOUR_KEY_ID:YOUR_SECRET_KEY

# Build context for docker/agent-python.Dockerfile. The image bakes only the harness CODE the agent
# runtime needs; everything heavy, host-specific, or scoring-related is excluded.

# Heavy / host-specific / regenerated
node_modules
checkouts
otel
logs
reports
tmp
runs.jsonl
.git

# Mounted at runtime, not baked
agent-skill

# The eval "answer key" (src/evaluation.ts, weaver.ts, envvars.ts, EVALUATION.md, apps/) is now BAKED
# into the image — harness-mode entrypoints (eval/start) need it, and the agent step is protected by
# src/sandbox.ts (makeFsGuard's default-deny whitelist denies these paths just as on a host run). So it
# is intentionally NOT excluded here.

# Not needed inside the container — except the in-container lifecycle entrypoint, which is baked.
docker
!docker/lifecycle.sh
.env
